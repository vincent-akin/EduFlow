{
    "name": "eduflow-backend",
    "version": "1.0.0",
    "description": "EduFlow - AI-Powered Assessment & Academic Productivity Platform",
    "type": "module",
    "imports": {
        "#src/*": "./src/*",
        "#modules/*": "./src/modules/*",
        "#shared/*": "./src/shared/*",
        "#utils/*": "./src/utils/*",
        "#types/*": "./src/types/*",
        "#config/*": "./src/config/*",
        "#middlewares/*": "./src/middlewares/*"
    },
    "scripts": {
        "dev": "nodemon --exec node --import tsx src/server.ts",
        "start": "node dist/server.js",
        "build": "tsc -p tsconfig.build.json",
        "test": "node --import tsx src/test-logger.ts",
        "lint": "eslint . --ext .ts",
        "format": "prettier --write ."
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.0.0",
        "helmet": "^7.0.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.0",
        "pino": "^8.15.0",
        "pino-pretty": "^10.2.3",
        "slugify": "^1.6.9",
        "uuid": "^9.0.1",
        "zod": "^3.22.2"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.2",
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.17",
        "@types/jsonwebtoken": "^9.0.2",
        "@types/node": "^20.6.0",
        "@types/uuid": "^9.0.2",
        "@typescript-eslint/eslint-plugin": "^6.7.0",
        "@typescript-eslint/parser": "^6.7.0",
        "eslint": "^8.49.0",
        "nodemon": "^3.0.1",
        "prettier": "^3.0.3",
        "tsx": "^4.0.0",
        "typescript": "^5.2.2"
    }
}
