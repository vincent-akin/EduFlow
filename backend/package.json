{
    "name": "eduflow-backend",
    "version": "1.0.0",
    "description": "EduFlow - AI-Powered Assessment & Academic Productivity Platform",
    "type": "module",
    "imports": {
        "#src/*": "./src/*",
        "#modules/*": "./src/modules/*",
        "#shared/*": "./src/shared/*",
        "#utils/*": "./src/utils/*",
        "#types/*": "./src/types/*",
        "#config/*": "./src/config/*",
        "#middlewares/*": "./src/middlewares/*"
    },
    "scripts": {
        "dev": "nodemon --exec node --loader tsx src/server.ts",
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/server.js",
        "lint": "eslint . --ext .ts",
        "format": "prettier --write ."
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "express": "^4.22.2",
        "express-rate-limit": "^7.5.1",
        "helmet": "^7.2.0",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^8.24.1",
        "pino": "^8.21.0",
        "pino-pretty": "^10.3.1",
        "uuid": "^9.0.1",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.25",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.19.43",
        "@types/uuid": "^9.0.8",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "eslint": "^8.57.1",
        "nodemon": "^3.1.14",
        "prettier": "^3.9.4",
        "tsx": "^4.23.0",
        "typescript": "^5.9.3"
    }
}
